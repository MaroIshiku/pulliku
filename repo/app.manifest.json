{
  "app_id": "pulliku",
  "app_name": "Pulliku",
  "app_subtitle": "Media Download Interface",
  "app_symbol": "download",
  "app_logo": {
    "src": "/static/pulliku-logo.png",
    "favicon": "/static/pulliku-logo.png",
    "alt": "",
    "use_as_header_symbol": true,
    "use_as_favicon": true,
    "use_as_pwa_icon": false,
    "use_as_about_symbol": true,
    "use_as_profile_sheet_symbol": true,
    "use_as_empty_state_symbol": true
  },
  "primary_purpose": "Self-hosted web interface for media downloads with yt-dlp.",
  "main_sections": ["Download", "Queue"],
  "navigation_complexity": "single_view",
  "default_theme": "lavender",
  "default_mode": "system",
  "has_account": true,
  "first_run_setup": {
    "enabled": true,
    "route": "/setup",
    "require_setup_secret": true,
    "setup_secret_file_env": "ISHIKU_SETUP_SECRET_FILE",
    "setup_secret_env": "ISHIKU_SETUP_SECRET",
    "setup_secret_file_default": "/run/secrets/ishiku_setup_secret",
    "public_registration_after_first_admin": false,
    "admin_password_must_differ_from_setup_secret": true,
    "minimum_admin_password_length": 12
  },
  "readme_profile": {
    "repository_name": "pulliku",
    "github_owner": "MaroIshiku",
    "public_repository": true,
    "short_description": "Pulliku is a calm, self-hosted web interface for media downloads.",
    "docker_image": "ghcr.io/maroishiku/pulliku:latest",
    "codex_notice_enabled": true
  }
}

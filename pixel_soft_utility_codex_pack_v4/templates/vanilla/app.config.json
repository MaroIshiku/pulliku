{
  "app_id": "pulliku",
  "app_name": "Pulliku",
  "app_subtitle": "Medien herunterladen",
  "app_symbol": "download",
  "app_logo": {
    "src": "assets/logos/pulliku.svg",
    "light_src": "assets/logos/pulliku.svg",
    "dark_src": "assets/logos/pulliku-dark.svg",
    "favicon": "assets/logos/pulliku.svg",
    "pwa_icon_192": "assets/pwa/pulliku-192.png",
    "pwa_icon_512": "assets/pwa/pulliku-512.png",
    "pwa_maskable_512": "assets/pwa/pulliku-maskable-512.png",
    "alt": "",
    "use_as_header_symbol": true,
    "use_as_favicon": true,
    "use_as_pwa_icon": true,
    "use_as_about_symbol": true,
    "use_as_profile_sheet_symbol": true,
    "use_as_empty_state_symbol": true
  },
  "primary_purpose": "YTDLP Webinterface mit URL-Eingabe, Download-Einstellungen, Queue und Verlauf.",
  "main_sections": [
    "Download",
    "Queue",
    "Verlauf"
  ],
  "navigation_complexity": "few_sections",
  "default_theme": "lavender",
  "default_mode": "system",
  "has_account": true,
  "first_run_setup": {
    "enabled": true,
    "route": "/setup",
    "require_setup_secret": true,
    "setup_secret_file_env": "ISHIKU_SETUP_SECRET_FILE",
    "setup_secret_env": "ISHIKU_SETUP_SECRET",
    "setup_secret_file_default": "/run/secrets/ishiku_setup_secret",
    "public_registration_after_first_admin": false,
    "admin_password_must_differ_from_setup_secret": true,
    "minimum_admin_password_length": 12
  },
  "readme_profile": {
    "repository_name": "pulliku",
    "public_repository": true,
    "short_description": "Pulliku ist ein ruhiges, self-hosted Webinterface für Medien-Downloads.",
    "docker_image": "ghcr.io/{OWNER}/pulliku:latest",
    "codex_notice_enabled": true
  }
}
